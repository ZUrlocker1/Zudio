<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Zudio</string>
    <key>CFBundleIdentifier</key>
    <string>com.zudio.app</string>
    <key>CFBundleVersion</key>
    <string>110</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>Zudio</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.music</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>CFBundleIconFile</key>
    <string>zudio-icon</string>

    <!-- Prevent macOS from launching a second process when opening .zudio files -->
    <key>LSMultipleInstancesProhibited</key>
    <true/>

    <!-- Custom document type: .zudio song files -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Zudio Song</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>zudio</string>
            </array>
            <key>CFBundleTypeIconFile</key>
            <string>zudio-doc</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.zudio.song</string>
            </array>
        </dict>
    </array>

    <!-- Declare the UTI so macOS knows com.zudio.song is a real type owned by this app -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.zudio.song</string>
            <key>UTTypeDescription</key>
            <string>Zudio Song</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.data</string>
            </array>
            <key>UTTypeIconFile</key>
            <string>zudio-doc</string>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>zudio</string>
                </array>
            </dict>
        </dict>
    </array>

    <!-- iOS: allow files to appear in Files app and be opened in place -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>

    <!-- No custom encryption used — exempt from export compliance -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
</dict>
</plist>
